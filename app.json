{
  "name": "Lunar",
  "slug": "lunar",
  "displayName": "Lunar",
  "icon": "./assets/icon.png",
  "extra": {
    "eas": {
      "projectId": "6492eb54-5fe6-4a6e-b84d-9df5d43ef2ea"
    }
  },
  "updates": {
    "checkAutomatically": "NEVER",
    "url": "https://u.expo.dev/6492eb54-5fe6-4a6e-b84d-9df5d43ef2ea"
  },
  "android": {
    "package": "com.lunar.app",
    "runtimeVersion": "1.2.1",
    "adaptiveIcon": {
      "foregroundImage": "./assets/adaptive-icon.png",
      "monochromeImage": "./assets/monochrome-icon.png",
      "backgroundColor": "#041737"
    },
    "intentFilters": [
      {
        "action": "VIEW",
        "category": ["DEFAULT"],
        "data": [
          { "scheme": "file" },
          { "scheme": "content" },
          { "mimeType": "application/x-cbz" },
          { "mimeType": "application/vnd.comicbook+zip" }
        ]
      },
      {
        "action": "VIEW",
        "category": ["DEFAULT"],
        "data": [
          { "host": "*" },
          { "scheme": "file" },
          { "scheme": "content" },
          { "pathPattern": ".*\\\\.cbz" },
          { "pathPattern": ".*\\\\..*\\\\.cbz" }
        ]
      }
    ]
  },
  "experiments": {
    "reactCompiler": true
  },
  "plugins": [
    [
      "expo-video",
      {
        "supportsBackgroundPlayback": true,
        "supportsPictureInPicture": true
      }
    ],
    "expo-sqlite"
  ]
}
