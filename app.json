{
  "name": "AniFlix",
  "slug": "lunar",
  "displayName": "AniFlix",
  "extra": {
    "eas": {
      "projectId": "a8fab8df-a6fc-4724-b527-fc05c98c90cc"
    }
  },
  "updates": {
    "checkAutomatically": "NEVER",
    "url": "https://u.expo.dev/a8fab8df-a6fc-4724-b527-fc05c98c90cc"
  },
  "android": {
    "package": "com.hiura.aniflix",
    "runtimeVersion": "1.2.1",
    "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT"],
          "data": [
            { "scheme": "file" },
            { "scheme": "content" },
            { "mimeType": "application/x-cbz" },
            { "mimeType": "application/vnd.comicbook+zip" }
          ]
        },
        {
          "action": "VIEW",
          "category": ["DEFAULT"],
          "data": [
            { "host": "*" },
            { "scheme": "file" },
            { "scheme": "content" },
            { "pathPattern": ".*\\\\.cbz" },
            { "pathPattern": ".*\\\\.cbz" },
            { "pathPattern": ".*\\\\..*\\\\.cbz" },
            { "pathPattern": ".*\\\\..*\\\\.cbz" }
          ]
        }
      ]
  },
  "experiments": {
    "reactCompiler": true
  },
  "plugins": [
    [
      "expo-video",
      {
        "supportsBackgroundPlayback": true,
        "supportsPictureInPicture": true
      }
    ],
    "expo-sqlite"
  ]
}
